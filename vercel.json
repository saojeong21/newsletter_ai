{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "250mb",
        "includeFiles": [
          "app/templates/**",
          "app/summarizer.py",
          "app/crawler.py",
          "app/scheduler.py",
          "app/sources.py",
          "app/supabase_db.py",
          "app/__init__.py",
          "app/main.py",
          "app/database.py",
          "app/models.py"
        ]
      }
    },
    {
      "src": "app/static/(.*)",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/app/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
