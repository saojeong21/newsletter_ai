{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/collect",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/summarize",
      "schedule": "20 22 * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "app/**"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/public/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
